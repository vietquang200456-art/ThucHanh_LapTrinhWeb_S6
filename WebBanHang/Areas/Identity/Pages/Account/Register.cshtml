@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4">

                    <h2 class="text-center fw-bold mb-3">Create Account</h2>
                    <p class="text-center text-muted mb-4">Join with us today 🚀</p>

                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                        <!-- FULL NAME -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.FullName" class="form-control" placeholder="Full Name" />
                            <label asp-for="Input.FullName">Họ tên</label>
                            <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                        </div>

                        <!-- ADDRESS -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Address" class="form-control" placeholder="Address" />
                            <label asp-for="Input.Address">Địa chỉ</label>
                            <span asp-validation-for="Input.Address" class="text-danger small"></span>
                        </div>

                        <!-- AGE -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Age" class="form-control" placeholder="Age" />
                            <label asp-for="Input.Age">Tuổi</label>
                            <span asp-validation-for="Input.Age" class="text-danger small"></span>
                        </div>

                        <!-- EMAIL -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" placeholder="Email" />
                            <label asp-for="Input.Email">Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <!-- PASSWORD -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" placeholder="Password" />
                            <label asp-for="Input.Password">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <!-- CONFIRM PASSWORD -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Confirm Password" />
                            <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <!-- ROLE -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Role</label>
                            <select asp-for="Input.Role"
                                    asp-items="@Model.Input.RoleList"
                                    class="form-select">
                                <option disabled selected>-- Select Role --</option>
                            </select>
                        </div>

                        <!-- BUTTON -->
                        <button id="registerSubmit"
                                type="submit"
                                class="btn btn-primary w-100 py-2 fw-semibold">
                            Register
                        </button>

                    </form>
                </div>
            </div>

            <!-- EXTERNAL LOGIN -->
            <div class="card mt-4 shadow-sm border-0 rounded-4">
                <div class="card-body text-center">

                    <h5 class="mb-3">Or sign up with</h5>

                    @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                    {
                        <p class="text-muted small">
                            No external login configured
                        </p>
                    }
                    else
                    {
                        <form asp-page="./ExternalLogin"
                              asp-route-returnUrl="@Model.ReturnUrl"
                              method="post">

                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit"
                                        class="btn btn-outline-dark me-2 mb-2"
                                        name="provider"
                                        value="@provider.Name">
                                    @provider.DisplayName
                                </button>
                            }
                        </form>
                    }

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}