@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card register-card shadow-lg p-3 p-md-4">
                <div class="card-body">

                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-dark">Create Account</h2>
                        <p class="text-muted small">Join our community and start shopping 🚀</p>
                    </div>

                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small rounded-3" role="alert"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <div class="form-floating">
                                    <input asp-for="Input.FullName" class="form-control" placeholder="Full Name" />
                                    <label asp-for="Input.FullName" class="text-muted small">Full Name</label>
                                    <span asp-validation-for="Input.FullName" class="text-danger extra-small"></span>
                                </div>
                            </div>

                            <div class="col-md-8">
                                <div class="form-floating">
                                    <input asp-for="Input.Address" class="form-control" placeholder="Address" />
                                    <label asp-for="Input.Address" class="text-muted small">Address</label>
                                    <span asp-validation-for="Input.Address" class="text-danger extra-small"></span>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-floating">
                                    <input asp-for="Input.Age" class="form-control" placeholder="Age" />
                                    <label asp-for="Input.Age" class="text-muted small">Age</label>
                                    <span asp-validation-for="Input.Age" class="text-danger extra-small"></span>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-floating">
                                    <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                                    <label asp-for="Input.Email" class="text-muted small">Email Address</label>
                                    <span asp-validation-for="Input.Email" class="text-danger extra-small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Password" />
                                    <label asp-for="Input.Password" class="text-muted small">Password</label>
                                    <span asp-validation-for="Input.Password" class="text-danger extra-small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                                    <label asp-for="Input.ConfirmPassword" class="text-muted small">Confirm</label>
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger extra-small"></span>
                                </div>
                            </div>

                            <div class="col-12 mb-3">
                                <label class="form-label small fw-bold text-muted ps-1">Role</label>
                                <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select py-3">
                                    <option disabled selected>-- Select Role --</option>
                                </select>
                            </div>
                        </div>

                        <button id="registerSubmit" type="submit" class="btn btn-register w-100 py-3 fw-bold mb-3 shadow-sm">
                            Register Account
                        </button>

                        <p class="text-center small text-muted mb-0">
                            Already have an account?
                            <a asp-page="./Login" class="text-decoration-none fw-bold text-primary">Login Now</a>
                        </p>
                    </form>

                    <div class="divider text-uppercase fw-bold tracking-wider">or join with</div>

                    <div class="text-center">
                        @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                        {
                            <p class="text-muted extra-small italic">No external services configured.</p>
                        }
                        else
                        {
                            <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="d-flex justify-content-center gap-2">
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn external-btn px-4 py-2" name="provider" value="@provider.Name">
                                        @provider.DisplayName
                                    </button>
                                }
                            </form>
                        }
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #4361ee, #4cc9f0);
    }

    body {
        background-color: #f8f9fa;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .register-card {
        border-radius: 25px !important;
        border: none;
        background: #ffffff;
    }

    .form-floating > .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
    }

        .form-floating > .form-control:focus, .form-select:focus {
            border-color: #4361ee;
            box-shadow: 0 0 0 4px rgba(67, 97, 238, 0.1);
        }

    .btn-register {
        background: var(--primary-gradient);
        border: none;
        border-radius: 12px;
        color: white;
        transition: all 0.3s;
    }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(67, 97, 238, 0.3);
            color: white;
        }

    .external-btn {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        transition: all 0.2s;
        font-weight: 500;
    }

    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        color: #94a3b8;
        font-size: 0.85rem;
        margin: 25px 0;
    }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #e2e8f0;
        }

        .divider:not(:empty)::before {
            margin-right: .75em;
        }

        .divider:not(:empty)::after {
            margin-left: .75em;
        }
</style>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}