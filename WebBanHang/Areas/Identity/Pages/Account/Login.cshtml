@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-5">

            <!-- LOGIN CARD -->
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4">

                    <h2 class="text-center fw-bold mb-3">Welcome Back 👋</h2>
                    <p class="text-center text-muted mb-4">Login to your account</p>

                    <form id="account" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                        <!-- EMAIL -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email"
                                   class="form-control"
                                   placeholder="Email" />
                            <label asp-for="Input.Email">Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <!-- PASSWORD -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password"
                                   class="form-control"
                                   placeholder="Password" />
                            <label asp-for="Input.Password">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <!-- REMEMBER -->
                        <div class="form-check mb-3">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label" asp-for="Input.RememberMe">
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </label>
                        </div>

                        <!-- BUTTON -->
                        <button id="login-submit"
                                type="submit"
                                class="btn btn-primary w-100 py-2 fw-semibold">
                            Log in
                        </button>

                        <!-- LINKS -->
                        <div class="text-center mt-3">

                            <a id="forgot-password"
                               asp-page="./ForgotPassword"
                               class="d-block small text-decoration-none">
                                Forgot password?
                            </a>

                            <a asp-page="./Register"
                               asp-route-returnUrl="@Model.ReturnUrl"
                               class="d-block small text-decoration-none mt-1">
                                Create new account
                            </a>

                            <a id="resend-confirmation"
                               asp-page="./ResendEmailConfirmation"
                               class="d-block small text-decoration-none mt-1">
                                Resend confirmation email
                            </a>

                        </div>

                    </form>
                </div>
            </div>

            <!-- EXTERNAL LOGIN -->
            <div class="card mt-4 shadow-sm border-0 rounded-4">
                <div class="card-body text-center">

                    <h5 class="mb-3">Or login with</h5>

                    @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                    {
                        <p class="text-muted small">
                            No external login configured
                        </p>
                    }
                    else
                    {
                        <form asp-page="./ExternalLogin"
                              asp-route-returnUrl="@Model.ReturnUrl"
                              method="post">

                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit"
                                        class="btn btn-outline-dark me-2 mb-2"
                                        name="provider"
                                        value="@provider.Name">
                                    @provider.DisplayName
                                </button>
                            }
                        </form>
                    }

                </div>
            </div>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}