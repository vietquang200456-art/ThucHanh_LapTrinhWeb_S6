@model WebBanHang.Models.Category

@{
    ViewData["Title"] = "Create Category";
}

<style>
    .create-card {
        border-radius: 25px !important;
        border: none;
        background: #ffffff;
    }

    .form-floating > .form-control {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
    }

        .form-floating > .form-control:focus {
            border-color: #4361ee;
            box-shadow: 0 0 0 4px rgba(67, 97, 238, 0.1);
        }

    .btn-save {
        background: linear-gradient(135deg, #4361ee, #4cc9f0);
        border: none;
        border-radius: 12px;
        color: white;
        transition: all 0.3s;
        padding: 12px;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(67, 97, 238, 0.3);
            color: white;
        }

    .btn-back {
        border-radius: 12px;
        color: #64748b;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-back:hover {
            color: #1e293b;
        }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="mb-4">
                <a asp-action="Index" class="btn-back small fw-bold">
                    ← Back to List
                </a>
            </div>

            <div class="card create-card shadow-lg p-3 p-md-4">
                <div class="card-body">

                    <div class="text-center mb-4">
                        <div class="display-6 mb-2">📁</div>
                        <h2 class="fw-bold text-dark">New Category</h2>
                        <p class="text-muted small">Create a new group for your products</p>
                    </div>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Name" class="form-control" placeholder="Enter category name" autofocus />
                            <label asp-for="Name" class="text-muted small">Category Name</label>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-save fw-bold">
                                Create Category
                            </button>
                        </div>
                    </form>

                </div>
            </div>

            <p class="text-center mt-4 text-muted small">
                Tip: Use clear and concise names like "Electronics" or "Fashion".
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}