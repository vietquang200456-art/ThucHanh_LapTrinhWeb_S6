@model List<WebBanHang.Models.CartItem>
<div class="container py-5">
    <div class="d-flex align-items-center mb-5">
        <h2 class="fw-bold display-6 mb-0" style="color: #2b2d42;">🛒 Your <span class="text-primary">Shopping Cart</span></h2>
        <span class="badge bg-light text-primary ms-3 px-3 py-2 rounded-pill shadow-sm border">@Model.Count() Items</span>
    </div>

    @if (!Model.Any())
    {
        <div class="card card-modern shadow-sm text-center py-5">
            <div class="card-body">
                <div class="mb-4" style="font-size: 4rem;">🛍️</div>
                <h4 class="fw-bold">Your cart is feeling lonely...</h4>
                <p class="text-muted">Explore our latest products and fill it with joy!</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-modern px-5 shadow-sm mt-3">
                    Start Shopping Now
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                @foreach (var item in Model)
                {
                    <div class="card card-modern cart-item-card mb-3 shadow-sm p-3">
                        <div class="row g-0 align-items-center">
                            <div class="col-3 col-md-2 text-center">
                                <img src="@item.ImageUrl" class="product-img-cart shadow-sm" alt="@item.Name" />
                            </div>

                            <div class="col-6 col-md-5 ps-3">
                                <h6 class="fw-bold mb-1 text-dark">@item.Name</h6>
                                <p class="text-primary fw-bold mb-0">@item.Price.ToString("N0") <small>đ</small></p>
                            </div>

                            <div class="col-12 col-md-3 mt-3 mt-md-0 d-flex justify-content-center">
                                <form asp-action="UpdateQuantity" method="post" class="quantity-control">
                                    <input type="hidden" name="ProductId" value="@item.ProductId" />
                                    <button class="btn btn-sm btn-light border-0 rounded-circle" type="submit" name="action" value="decrease" style="width:30px; height:30px;">-</button>
                                    <input type="text" name="Quantity" value="@item.Quantity" class="quantity-input" readonly />
                                    <button class="btn btn-sm btn-light border-0 rounded-circle" type="submit" name="action" value="increase" style="width:30px; height:30px;">+</button>
                                </form>
                            </div>

                            <div class="col-3 col-md-2 text-end">
                                <a asp-action="Remove" asp-route-id="@item.ProductId" class="btn btn-light btn-modern text-danger p-2 border-0">
                                    <i class="bi bi-trash"></i> 🗑
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="card card-modern shadow-sm p-4 summary-box">
                    <h5 class="fw-bold mb-4">Order Summary</h5>
                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Subtotal</span>
                        <span>@Model.Sum(i => i.Price * i.Quantity).ToString("N0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Shipping</span>
                        <span class="text-success fw-bold">Free</span>
                    </div>
                    <hr class="my-4 opacity-50">
                    <div class="d-flex justify-content-between mb-4 align-items-center">
                        <span class="fw-bold fs-5">Total</span>
                        <span class="fw-bold text-primary fs-4">@Model.Sum(i => i.Price * i.Quantity).ToString("N0") đ</span>
                    </div>

                    <div class="d-grid gap-2">
                        <a asp-controller="Checkout" asp-action="Index" class="btn btn-checkout btn-modern shadow-sm py-3">
                            Proceed to Checkout
                        </a>
                        <a asp-action="Clear" class="btn btn-light btn-modern text-muted py-2 small">
                            Clear Cart
                        </a>
                    </div>

                    <div class="mt-4 text-center">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg" height="20" class="mx-2 opacity-50" />
                        <img src="https://upload.wikimedia.org/wikipedia/commons/5/5e/Visa_Inc._logo.svg" height="15" class="mx-2 opacity-50" />
                        <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" height="20" class="mx-2 opacity-50" />
                    </div>
                </div>
            </div>
        </div>
    }
</div>
<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #4361ee, #4cc9f0);
        --danger-gradient: linear-gradient(135deg, #ff4d4d, #c0392b);
    }

    body {
        background-color: #f8f9fa;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .card-modern {
        border-radius: 20px !important;
        border: none;
        background: #ffffff;
        transition: all 0.3s ease;
    }

    .cart-item-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
    }

    .product-img-cart {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 15px;
    }

    .quantity-control {
        background: #f1f3f9;
        border-radius: 10px;
        padding: 4px;
        display: inline-flex;
        align-items: center;
    }

    .quantity-input {
        background: transparent;
        border: none;
        text-align: center;
        width: 40px;
        font-weight: 600;
    }

    .btn-modern {
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s;
        padding: 10px 20px;
    }

    .btn-checkout {
        background: var(--primary-gradient);
        color: white;
        border: none;
    }

        .btn-checkout:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(67, 97, 238, 0.3);
            color: white;
        }

    .summary-box {
        position: sticky;
        top: 20px;
    }
</style>