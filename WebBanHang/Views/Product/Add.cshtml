@model WebBanHang.Models.Product

@{
    ViewData["Title"] = "Add Product";
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card card-modern p-4 p-md-5">

                <div class="text-center mb-5">
                    <h2 class="fw-bold display-6" style="color: #2b2d42;">✨ Add <span class="text-success">New Product</span></h2>
                    <p class="text-muted">Fill in the details below to list a new item in your store</p>
                </div>

                <form asp-action="Add" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>

                    <div class="row g-4">
                        <div class="col-md-7">
                            <div class="mb-4">
                                <label asp-for="Name" class="form-label fw-bold text-uppercase small tracking-wider">Product Name</label>
                                <input asp-for="Name" class="form-control" placeholder="e.g. Premium Wireless Headphones" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <label asp-for="Price" class="form-label fw-bold text-uppercase small tracking-wider">Price (VNĐ)</label>
                                    <div class="input-group">
                                        <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                        <span class="input-group-text bg-light border-start-0 text-muted">đ</span>
                                    </div>
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CategoryId" class="form-label fw-bold text-uppercase small tracking-wider">Category</label>
                                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                                        <option value="">-- Select Category --</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mb-0">
                                <label asp-for="Description" class="form-label fw-bold text-uppercase small tracking-wider">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="6" placeholder="Describe the key features and benefits..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-5">
                            <label class="form-label fw-bold text-uppercase small tracking-wider">Product Visual</label>
                            <div class="mb-3">
                                <input type="file" name="imageFile" id="imageInput" class="form-control mb-3" onchange="previewImage(event)" />

                                <div class="preview-container mt-2">
                                    <img id="preview" src="#" class="img-fluid rounded-3 shadow-sm d-none" style="max-height: 280px; object-fit: contain;" />
                                    <div id="placeholder" class="text-center text-muted p-4">
                                        <div class="fs-1 mb-2">📸</div>
                                        <p class="small mb-0">Image preview will appear here</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-5 opacity-50">

                    <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                        <a asp-action="Index" class="btn btn-light btn-modern px-4">
                            <span class="me-2">←</span> Back to Gallery
                        </a>
                        <button type="submit" class="btn btn-save btn-modern px-5 shadow">
                            💾 Save & Publish Product
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #4361ee, #4cc9f0);
        --success-gradient: linear-gradient(135deg, #2ecc71, #27ae60);
    }

    body {
        background-color: #f8f9fa;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .card-modern {
        border-radius: 25px !important;
        border: none;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05) !important;
    }

    .form-label {
        color: #4a5568;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .form-control, .form-select {
        border-radius: 12px;
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        transition: all 0.3s;
    }

        .form-control:focus, .form-select:focus {
            border-color: #4361ee;
            box-shadow: 0 0 0 4px rgba(67, 97, 238, 0.1);
        }

    .preview-container {
        border: 2px dashed #e2e8f0;
        border-radius: 15px;
        padding: 10px;
        min-height: 150px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #fcfcfd;
    }

    .btn-modern {
        border-radius: 12px;
        padding: 12px 25px;
        font-weight: 600;
        transition: all 0.3s;
    }

    .btn-save {
        background: var(--success-gradient);
        border: none;
        color: white;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(46, 204, 113, 0.3);
            color: white;
        }
</style>

<script>
    function previewImage(event) {
        const input = event.target;
        const preview = document.getElementById("preview");
        const placeholder = document.getElementById("placeholder");

        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.classList.remove("d-none");
                placeholder.classList.add("d-none");
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>