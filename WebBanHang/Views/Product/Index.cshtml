@model IEnumerable<WebBanHang.Models.Product>

@{
    ViewData["Title"] = "Product List";
}

<div class="container mt-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">🛍 Product Store</h2>

        <a asp-action="Add" class="btn btn-success px-4">
            ➕ Add Product
        </a>
    </div>

    <!-- PRODUCT GRID -->
    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">

                <div class="card h-100 shadow-sm border-0 rounded-4 product-card">

                    <!-- IMAGE -->
                    <div class="overflow-hidden rounded-top-4">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl"
                                 class="card-img-top"
                                 style="height:200px; object-fit:cover;" />
                        }
                        else
                        {
                            <div class="text-center p-5 text-muted">No Image</div>
                        }
                    </div>

                    <!-- BODY -->
                    <div class="card-body d-flex flex-column">

                        <h6 class="fw-bold text-truncate">
                            @item.Name
                        </h6>

                        <p class="text-danger fw-bold mb-2">
                            @item.Price.ToString("N0") đ
                        </p>

                        <span class="badge bg-primary mb-2">
                            @item.Category?.Name
                        </span>

                        <p class="text-muted small text-truncate">
                            @item.Description
                        </p>

                        <div class="mt-auto">

                            <a asp-action="Display"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-primary btn-sm w-100 mb-1">
                                👁 View
                            </a>

                            <div class="d-flex gap-1">
                                <a asp-action="Update"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm w-50">
                                    ✏️
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm w-50">
                                    🗑
                                </a>
                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

<!-- STYLE -->
<style>
    .product-card {
        transition: 0.3s;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }
</style>