@model WebBanHang.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card card-modern p-4 p-md-5">

                <div class="text-center mb-5">
                    <h2 class="fw-bold display-6" style="color: #2b2d42;">✏️ Edit <span class="text-warning">Product</span></h2>
                    <p class="text-muted">Modify the information for ID: <span class="badge bg-light text-dark">#@Model.Id</span></p>
                </div>

                <form asp-action="Update" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImageUrl" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small"></div>

                    <div class="row g-4">
                        <div class="col-md-7">
                            <div class="mb-4">
                                <label asp-for="Name" class="form-label fw-bold text-uppercase tracking-wider">Product Name</label>
                                <input asp-for="Name" class="form-control" placeholder="Enter name..." />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <label asp-for="Price" class="form-label fw-bold text-uppercase tracking-wider">Price (VNĐ)</label>
                                    <div class="input-group">
                                        <input asp-for="Price" type="number" step="0.01" class="form-control" />
                                        <span class="input-group-text bg-light border-start-0 text-muted small">đ</span>
                                    </div>
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CategoryId" class="form-label fw-bold text-uppercase tracking-wider">Category</label>
                                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                                        <option value="">-- Select Category --</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mb-0">
                                <label asp-for="Description" class="form-label fw-bold text-uppercase tracking-wider">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-5">
                            <div class="mb-4">
                                <label class="form-label fw-bold text-uppercase tracking-wider d-block mb-3">Product Visuals</label>

                                <div class="image-preview-box mb-3">
                                    <p class="small text-muted mb-2">Current Image</p>
                                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                    {
                                        <img src="~/images/@Model.ImageUrl" class="img-fluid rounded-3 shadow-sm" style="max-height: 120px; object-fit: contain;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted small italic">No image set</span>
                                    }
                                </div>

                                <div class="mb-3">
                                    <label class="form-label small text-muted">Upload New Image (Optional)</label>
                                    <input type="file" name="imageFile" class="form-control mb-2" onchange="previewImage(event)" />

                                    <div id="new-preview-container" class="image-preview-box d-none">
                                        <p class="small text-success mb-2">New Preview</p>
                                        <img id="preview" src="#" class="img-fluid rounded-3 shadow-sm" style="max-height: 120px; object-fit: contain;" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-5 opacity-50">

                    <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                        <a asp-action="Index" class="btn btn-light btn-modern px-4 text-muted">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-update btn-modern px-5 shadow">
                            💾 Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<style>
    :root {
        --warning-gradient: linear-gradient(135deg, #f39c12, #f1c40f);
    }

    body {
        background-color: #f8f9fa;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .card-modern {
        border-radius: 25px !important;
        border: none;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05) !important;
    }

    .form-label {
        color: #4a5568;
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
    }

    .form-control, .form-select {
        border-radius: 12px;
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        transition: all 0.3s;
    }

        .form-control:focus {
            border-color: #f39c12;
            box-shadow: 0 0 0 4px rgba(243, 156, 18, 0.1);
        }

    .image-preview-box {
        border: 2px dashed #e2e8f0;
        border-radius: 15px;
        padding: 15px;
        background-color: #fcfcfd;
        text-align: center;
    }

    .btn-modern {
        border-radius: 12px;
        padding: 12px 25px;
        font-weight: 600;
        transition: all 0.3s;
    }

    .btn-update {
        background: var(--warning-gradient);
        border: none;
        color: white;
    }

        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(243, 156, 18, 0.3);
            color: white;
        }
</style>
<script>
    function previewImage(event) {
        const input = event.target;
        const preview = document.getElementById("preview");
        const container = document.getElementById("new-preview-container");

        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                container.classList.remove("d-none");
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>